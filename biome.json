{
  "$schema": "https://biomejs.dev/schemas/latest/schema.json",
  "files": {
    "includes": [
      "**",
      "!**/*.html",
      "!src/assets/generated",
      "!public/generated"
    ]
  },
  "formatter": {
    "enabled": true,
    "lineWidth": 80,
    "indentStyle": "space",
    "indentWidth": 2
  },
  "linter": {
    "enabled": true,
    "rules": {
      "style": {
        "useConst": "off",
        "useImportType": "off",
        "useNodejsImportProtocol": "off",
        "noNonNullAssertion": "off",
        "useTemplate": "off"
      },
      "complexity": {
        "noBannedTypes": "off",
        "noThisInStatic": "off",
        "noUselessUndefinedInitialization": "off",
        "useLiteralKeys": "off"
      },
      "correctness": {
        "noSwitchDeclarations": "off",
        "noUnusedFunctionParameters": "off",
        "noUnusedPrivateClassMembers": "off",
        "noUnusedVariables": "off"
      },
      "suspicious": {
        "noExplicitAny": "off",
        "noShadowRestrictedNames": "off",
        "noDoubleEquals": "off",
        "noFocusedTests": "off",
        "noImplicitAnyLet": "off",
        "noSelfCompare": "off",
        "noThenProperty": "off",
        "noTsIgnore": "off",
        "useGetterReturn": "off"
      }
    }
  },
  "javascript": {
    "formatter": {
      "semicolons": "always",
      "quoteStyle": "double",
      "quoteProperties": "asNeeded",
      "trailingCommas": "all",
      "bracketSpacing": false,
      "arrowParentheses": "asNeeded"
    }
  }
}
